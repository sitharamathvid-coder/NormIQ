# ────────────────────────────────────────────────────────────
# NormIQ — Environment Configuration Template
# ────────────────────────────────────────────────────────────

# ── OpenAI ──────────────────────────────────────────────────
# Required for embeddings and LLM answer generation
OPENAI_API_KEY=your_openai_api_key_here

# ── Pinecone ─────────────────────────────────────────────────
# Required for vector search
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=compliance-rag

# ── Cohere ───────────────────────────────────────────────────
# Optional but recommended for high-accuracy reranking
COHERE_API_KEY=your_cohere_api_key_here

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (psycopg2)
DATABASE_URL=postgresql://user:password@localhost:5432/normiq

# ── Telegram ─────────────────────────────────────────────────
# Required for compliance officer alerts and review bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_OFFICER_CHAT_ID=your_chat_id_here

# ── Pipeline Settings ────────────────────────────────────────
# Threshold for direct answers vs human-in-the-loop review
CONFIDENCE_THRESHOLD=0.80

# Cache expiry in days
CACHE_EXPIRY_DAYS=90

# ── Langfuse (Monitoring) ────────────────────────────────────
# Optional: Set these if you want to enable RAG monitoring
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
